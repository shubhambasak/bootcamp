{"name":"E. Print Table of 5","group":"Codeforces - Introduction to C++","url":"https://codeforces.com/group/4vcXCPx8NY/contest/664504/problem/E","interactive":false,"memoryLimit":256,"timeLimit":1000,"tests":[{"id":1769578398402,"input":"There is no input.\n","output":"5 * 1 = 5\n5 * 2 = 10\n5 * 3 = 15\n5 * 4 = 20\n5 * 5 = 25\n5 * 6 = 30\n5 * 7 = 35\n5 * 8 = 40\n5 * 9 = 45\n5 * 10 = 50\n"}],"testType":"single","input":{"type":"stdin"},"output":{"type":"stdout"},"languages":{"java":{"mainClass":"Main","taskClass":"EPrintTableOf5"}},"batch":{"id":"d34f0310-2b77-4318-873a-15b64087b7cd","size":1},"srcPath":"/home/voz/codes/bootcamp/dsa/intro-to-cpp/E_Print_Table_of_5.cpp"}